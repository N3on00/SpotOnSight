(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}

spotonsight.com, www.spotonsight.com {
    encode zstd gzip
    import security_headers

    redir /api /api/ 308

    handle_path /api/* {
        reverse_proxy prod-backend:8000
    }

    handle {
        reverse_proxy prod-frontend:8080
    }
}

dev.spotonsight.com {
    encode zstd gzip
    import security_headers

    redir /api /api/ 308

    handle_path /api/* {
        reverse_proxy dev-backend:8000
    }

    handle {
        reverse_proxy dev-frontend:8080
    }
}
