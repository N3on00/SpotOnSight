# SpotOnSight staging environment template.
# Copy this file to .env.staging and replace every placeholder.

APP_ENV_FILE=.env.staging

MONGO_URL=mongodb://mongo:27017
MONGO_DB=spot_on_sight_staging
MONGO_AUTH_DB=SpotOnSightAuthStaging
MONGO_SPOTS_DB=spot_on_sight_staging
MONGO_SERVER_SELECTION_TIMEOUT_MS=2000

JWT_SECRET=replace-with-a-strong-staging-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Set this to the public staging origin used by browsers.
CORS_ORIGINS=https://staging.example.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-unique-staging-admin-password
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY=System Administrator

# Frontend build-time variables.
VITE_API_BASE_URL=/api
VITE_SUPPORT_EMAIL=support@example.com
