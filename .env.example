# SpotOnSight local development environment template.
# Copy this file to .env for docker compose development usage.

APP_ENV_FILE=.env

MONGO_URL=mongodb://mongo:27017
MONGO_DB=spot_on_sight
MONGO_AUTH_DB=SpotOnSightAuth
MONGO_SPOTS_DB=spot_on_sight
MONGO_SERVER_SELECTION_TIMEOUT_MS=2000

JWT_SECRET=replace-with-a-local-development-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_DISPLAY=System Administrator

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPPORT_EMAIL=support@example.com
